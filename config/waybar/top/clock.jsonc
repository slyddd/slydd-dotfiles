{
  "clock": {
    "interval": 60,
    "format": "{:%a, %d %b · %H:%M}",
    "max-length": 25,
    "tooltip-format": "{tz_list}",
    "timezones": ["America/Bogota", "Europe/Madrid"],
    "on-click": "hyprctl dispatch \"hl.dsp.exec_cmd('kitty -e calcure', { float = true, size = {800, 500}, center = true })\"",
  },
}
